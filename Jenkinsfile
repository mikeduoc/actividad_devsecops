pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                echo 'Iniciando etapa de Build...'
                echo 'Compilando el proyecto Hello World...'
            }
        }
        stage('Test') {
            steps {
                echo 'Iniciando etapa de Test...'
                echo 'Ejecutando pruebas unitarias de seguridad base...'
            }
        }
        stage('Deploy') {
            steps {
                echo 'Iniciando etapa de Deploy...'
                echo 'Desplegando la aplicación en servidor de pre-producción...'
            }
        }
    }
}
